PORT=5000
JWT_SECRET=cambia_esto_por_un_secreto_largo
JWT_EXPIRACION=7d

# demo = funciona sin base de datos
# mongodb = preparado para futura migracion
# mysql = solo si quieres usar el backend antiguo Sequelize
DB_PROVIDER=demo

# Futuro MongoDB
MONGODB_URI=mongodb://localhost:27017/pixara

FRONTEND_URL=http://localhost:5173

# OAuth social. Rellena estas claves cuando vayas a activar login real.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/autenticacion/oauth/callback

APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_CALLBACK_URL=http://localhost:5000/api/autenticacion/oauth/callback
